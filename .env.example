# Supabase (required) — create a project at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Encryption (required) — for IMAP credential storage. Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Cron (required) — random secret for /api/upinbox/cron/tick. Generate: openssl rand -hex 32
CRON_SECRET=

# UpGPT license verification dev mode (optional)
# Set to true to skip JWT signature verification for local development.
# NEVER set true in production.
UPGPT_LICENSE_DEV_MODE=false

# Web Push (optional) — for push notifications. Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com
