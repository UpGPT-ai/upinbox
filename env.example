# UpInbox Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local — it's in .gitignore.
#
# BYOK keys (Claude/GPT/Gemini) are stored in the user's browser ONLY.
# They are not configured here and never transmitted to UpInbox servers.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Credential Encryption ────────────────────────────────────────────────────
# 32-byte AES-256-GCM key for stored IMAP/JMAP credentials.
# THIS IS YOUR KEY. UpInbox never sees it. Store in your secret manager.
# Generate: openssl rand -hex 32
PLATFORM_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# ─── OAuth Providers ──────────────────────────────────────────────────────────
# Gmail OAuth — create at console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Outlook OAuth — create at portal.azure.com (App registrations)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ─── License (Self-Host Business/Enterprise) ──────────────────────────────────
# Obtain at: https://upinbox.ai/licenses
# Community tier (≤10 users, heuristic classification): leave blank.
LICENSE_JWT=

# ─── Intelligence API ─────────────────────────────────────────────────────────
# Self-hosted instances route here for 95% accuracy classification (license required).
INTELLIGENCE_API_URL=https://api.upinbox.ai

# ─── Stalwart Mail Server ─────────────────────────────────────────────────────
# Only needed if hosting @yourdomain.com email addresses via Stalwart.
STALWART_ADMIN_SECRET=
STALWART_JMAP_URL=http://localhost:8080

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
INSTANCE_DOMAIN=localhost

# ─── Optional: Stripe (for self-hosted license management UI) ─────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
