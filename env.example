# ─── Database ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Encryption ────────────────────────────────────────────────────────────────
# 32-byte random key for AES-256-GCM encryption of stored IMAP credentials.
# Generate: openssl rand -hex 32
# SELF-HOST: This is YOUR key. UpInbox never sees it. Store in your secret manager.
PLATFORM_ENCRYPTION_KEY=replace-with-32-byte-hex-key

# ─── License (Self-Host Business/Enterprise) ──────────────────────────────────
# Obtain at: https://upinbox.ai/licenses
# Leave blank for Community tier (≤10 users, heuristic classification only).
LICENSE_JWT=

# ─── Intelligence API ─────────────────────────────────────────────────────────
# Self-hosted instances route here for 95% accuracy classification.
INTELLIGENCE_API_URL=https://api.upinbox.ai/v1/intelligence

# ─── Stalwart Mail Server ─────────────────────────────────────────────────────
# Only needed if hosting @yourdomain.com email addresses.
STALWART_ADMIN_SECRET=
STALWART_JMAP_URL=http://localhost:8080

# ─── App ───────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001
INSTANCE_DOMAIN=localhost

# ─── Optional: Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
