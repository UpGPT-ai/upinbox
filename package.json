{
  "name": "upinbox",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source email intelligence layer. Connect Gmail, Outlook, or any IMAP server. BYOK AI. Zero-knowledge encryption. Self-hostable.",
  "homepage": "https://upinbox.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/UpGPT-ai/upinbox.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
