{
  "name": "@upinbox/extension",
  "version": "0.1.0",
  "private": true,
  "description": "UpInbox Chrome Extension — AI email intelligence for Gmail and Outlook",
  "scripts": {
    "dev": "webpack --watch --config webpack.config.js",
    "build": "webpack --config webpack.config.js",
    "build:prod": "NODE_ENV=production webpack --config webpack.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@upgpt-ai/email-classifier": "^0.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "copy-webpack-plugin": "^12.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.0"
  }
}
